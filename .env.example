# UCIN Studio — frontend env
#
# Dev: leave VITE_API_BASE empty so vite.config proxies /customer to the local
#      backend (UCIN_CP_URL, default http://localhost:8000). Live pricing then
#      reads from /customer/config; if the backend is down, the site falls back
#      to built-in prices and still renders fully.
#
# Prod (studio.ucin.in): point the client straight at the deployed control plane.
#   VITE_API_BASE=https://api.ucin.in

VITE_API_BASE=
